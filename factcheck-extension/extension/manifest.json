{
  "manifest_version": 3,
  "name": "Разбор манипуляций",
  "version": "1.0.0",
  "description": "Плавающая кнопка на любой странице: проверьте текст или ссылку на признаки ложной информации с помощью ИИ.",
  "host_permissions": ["https://factchecker-woad.vercel.app/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    }
  ]
}